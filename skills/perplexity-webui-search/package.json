{
  "name": "perplexity-webui-search",
  "version": "0.1.0",
  "description": "Agent skill helper that queries Perplexity through the web UI with Playwright.",
  "license": "MIT",
  "author": "Sofian-bll",
  "type": "module",
  "files": [
    "LICENSE",
    "README.md",
    "SKILL.md",
    "scripts/perplexity-core.js",
    "scripts/perplexity-core.test.mjs",
    "scripts/perplexity-query.js",
    "references/"
  ],
  "bin": {
    "perplexity-webui-search": "scripts/perplexity-query.js"
  },
  "scripts": {
    "search": "node scripts/perplexity-query.js",
    "test": "node --test",
    "check": "node --check scripts/perplexity-query.js && node --check scripts/perplexity-core.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
